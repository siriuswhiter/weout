/* ========== 通用样式 - 一起出游 ========== */

/* 页面容器 */
.page {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding-bottom: env(safe-area-inset-bottom);
}

.page-content {
  padding: var(--spacing-lg);
}

/* ===== 卡片 ===== */
.card {
  background-color: var(--color-bg-white);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-card);
}

/* ===== 分组标题 ===== */
.section-title {
  font-size: var(--font-sm);
  color: var(--color-text-placeholder);
  font-weight: 600;
  margin-bottom: var(--spacing-sm);
  padding-left: 4rpx;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

/* ===== 按钮系统 ===== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-xl);
  font-size: var(--font-md);
  font-weight: 600;
  padding: var(--spacing-md) var(--spacing-lg);
  border: none;
  line-height: 1.4;
  transition: opacity var(--transition-fast);
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, var(--color-primary) 0%, #6B8AFF 100%);
  color: var(--color-text-inverse);
  box-shadow: 0 4rpx 16rpx rgba(79, 110, 247, 0.3);
}

.btn-primary:active {
  opacity: 0.85;
  box-shadow: 0 2rpx 8rpx rgba(79, 110, 247, 0.2);
}

.btn-secondary {
  background-color: var(--color-bg-gray);
  color: var(--color-text);
}

.btn-secondary:active {
  background-color: var(--color-border);
}

.btn-outline {
  background-color: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary-soft);
}

.btn-outline:active {
  background-color: var(--color-primary-light);
}

.btn-small {
  font-size: var(--font-sm);
  padding: var(--spacing-xs) var(--spacing-md);
  border-radius: var(--radius-lg);
  font-weight: 500;
}

.btn-block {
  width: 100%;
}

/* ===== 标签 ===== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx var(--spacing-sm);
  border-radius: var(--radius-round);
  font-size: 22rpx;
  line-height: 1.3;
  font-weight: 500;
}

.tag-primary {
  background-color: var(--color-primary-light);
  color: var(--color-primary);
}

.tag-default {
  background-color: var(--color-bg-gray);
  color: var(--color-text-secondary);
}

.tag-warning {
  background-color: var(--color-warning-light);
  color: #D97706;
}

.tag-success {
  background-color: var(--color-success-light);
  color: #16A34A;
}

.tag-accent {
  background-color: var(--color-accent-light);
  color: var(--color-accent);
}

/* ===== 头像 ===== */
.avatar {
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-sm {
  width: 40rpx;
  height: 40rpx;
  font-size: var(--font-xs);
}

.avatar-md {
  width: 56rpx;
  height: 56rpx;
  font-size: var(--font-sm);
}

.avatar-lg {
  width: 80rpx;
  height: 80rpx;
  font-size: var(--font-md);
}

.avatar-text {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-inverse);
  font-weight: 600;
}

/* 头像组 */
.avatar-group {
  display: flex;
  align-items: center;
}

.avatar-group .avatar {
  margin-left: -8rpx;
  border: 3rpx solid var(--color-bg-white);
}

.avatar-group .avatar:first-child {
  margin-left: 0;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
}

.empty-state-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary-light) 0%, #E8ECFF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--spacing-lg);
}

.empty-state-text {
  font-size: var(--font-md);
  color: var(--color-text-secondary);
  font-weight: 500;
}

.empty-state-hint {
  font-size: var(--font-sm);
  color: var(--color-text-placeholder);
  margin-top: var(--spacing-xs);
}

.empty-state-action {
  margin-top: var(--spacing-xl);
}

/* ===== 输入框 ===== */
.input-field {
  background-color: var(--color-bg);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md) var(--spacing-lg);
  font-size: var(--font-md);
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color var(--transition-fast);
}

.input-field:focus {
  border-color: var(--color-primary-soft);
  background-color: var(--color-bg-white);
}

.input-label {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-sm);
  font-weight: 500;
}

/* ===== 分割线 ===== */
.divider {
  height: 1rpx;
  background-color: var(--color-border-light);
}

/* ===== 弹性布局 ===== */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

/* ===== 底部安全区 ===== */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 底部操作栏 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-top: 1rpx solid var(--color-border-light);
  padding: var(--spacing-md) var(--spacing-lg);
  padding-bottom: calc(var(--spacing-md) + env(safe-area-inset-bottom));
  display: flex;
  gap: var(--spacing-sm);
  z-index: 100;
}

/* ===== 遮罩层 ===== */
.overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(26, 26, 46, 0.45);
  z-index: 200;
}

/* ===== 加载状态 ===== */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl);
  color: var(--color-text-placeholder);
  font-size: var(--font-md);
}

/* ===== 渐变装饰 ===== */
.gradient-bg {
  background: linear-gradient(135deg, var(--color-primary) 0%, #6B8AFF 50%, #8B9FFF 100%);
}

.gradient-text {
  background: linear-gradient(135deg, var(--color-primary) 0%, #6B8AFF 100%);
  -webkit-background-clip: text;
  color: transparent;
}
