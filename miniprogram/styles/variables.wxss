/* ========== 样式变量 ========== */

/* 主色调 */
page {
  --color-primary: #007aff;
  --color-primary-light: #e8f4fd;
  --color-success: #52c41a;
  --color-success-light: #f0f7ee;
  --color-warning: #ffa94d;
  --color-warning-light: #fff3e0;
  --color-danger: #ff4d4f;
  --color-danger-light: #fff1f0;

  /* 文字颜色 */
  --color-text: #333333;
  --color-text-secondary: #666666;
  --color-text-placeholder: #999999;
  --color-text-disabled: #cccccc;

  /* 背景颜色 */
  --color-bg: #f5f5f5;
  --color-bg-white: #ffffff;
  --color-bg-gray: #f0f0f0;

  /* 边框 */
  --color-border: #f0f0f0;
  --color-border-light: #f5f5f5;

  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-round: 999rpx;

  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  /* 字号 */
  --font-xs: 20rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-xxl: 44rpx;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}
