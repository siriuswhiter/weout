/* ===== 模板管理页面 ===== */

.review-page {
  padding-bottom: 60rpx;
}

.review-header {
  padding: 40rpx 32rpx 24rpx;
}

.review-header__title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
}

.review-header__desc {
  font-size: var(--font-sm);
  color: var(--color-text-placeholder);
  margin-top: 8rpx;
}

.review-header__actions {
  margin-top: 20rpx;
  display: flex;
  gap: 16rpx;
}

.seed-btn {
  display: inline-block;
  margin: 0;
}

/* Tab 切换 */
.mgmt-tabs {
  display: flex;
  gap: 40rpx;
  padding: 0 32rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.mgmt-tab {
  position: relative;
  padding: 20rpx 0;
  font-size: var(--font-md);
  color: var(--color-text-secondary);
  font-weight: 500;
}

.mgmt-tab--active {
  color: var(--color-primary);
  font-weight: 700;
}

.mgmt-tab--active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: -1rpx;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  border-radius: 4rpx;
  background: var(--color-primary);
}

.mgmt-tab__badge {
  display: inline-block;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  padding: 0 8rpx;
  margin-left: 8rpx;
  font-size: 20rpx;
  color: #fff;
  background: #FF6B6B;
  border-radius: 16rpx;
  vertical-align: middle;
}

/* 工具栏：搜索 + 筛选 */
.mgmt-toolbar {
  padding: 24rpx 32rpx 0;
}

.mgmt-search__input {
  height: 72rpx;
  padding: 0 24rpx;
  background: var(--color-bg-gray);
  border-radius: var(--radius-lg);
  font-size: var(--font-sm);
}

.mgmt-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.mgmt-filter {
  padding: 8rpx 24rpx;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  background: var(--color-bg-gray);
  border-radius: var(--radius-round);
  border: 2rpx solid transparent;
}

.mgmt-filter--active {
  color: var(--color-primary);
  background: var(--color-primary-light);
  border-color: var(--color-primary);
}

.review-list {
  padding: 24rpx;
}
