<view class="page">
  <view class="form">
    <!-- 模板名称 -->
    <view class="form-group">
      <view class="input-label">模板名称</view>
      <input
        class="input-field"
        placeholder="给模板取个名字"
        value="{{name}}"
        bindinput="onNameInput"
        maxlength="30"
      />
    </view>

    <!-- 模板描述 -->
    <view class="form-group">
      <view class="input-label">模板描述 <text class="input-label__hint">（选填）</text></view>
      <textarea
        class="input-field desc-textarea"
        placeholder="简单介绍一下这个模板..."
        value="{{description}}"
        bindinput="onDescInput"
        maxlength="200"
        auto-height
      />
      <view class="desc-counter" wx:if="{{description.length > 0}}">{{description.length}}/200</view>
    </view>

    <!-- 标签选择 -->
    <view class="form-group">
      <view class="input-label">标签（可多选）</view>
      <view class="tags-wrap">
        <view
          wx:for="{{allTags}}"
          wx:key="*this"
          class="tag {{tagSelected[item] ? 'tag-primary' : 'tag-default'}}"
          data-tag="{{item}}"
          bindtap="onTagTap"
        >{{item}}</view>
      </view>
      <!-- 自定义标签输入 -->
      <view class="custom-tag-row">
        <input
          class="custom-tag-input"
          placeholder="添加自定义标签"
          value="{{customTagInput}}"
          bindinput="onCustomTagInput"
          bindconfirm="onAddCustomTag"
          maxlength="10"
          confirm-type="done"
        />
        <view class="custom-tag-add-btn" bindtap="onAddCustomTag">
          <view class="icon icon-sm icon-plus"></view>
          <text>添加</text>
        </view>
      </view>
    </view>

    <!-- 可见度 -->
    <view class="form-group">
      <view class="input-label">可见度</view>
      <picker range="{{visibilityOptions}}" range-key="label" value="{{visibilityIndex}}" bindchange="onVisibilityChange">
        <view class="input-field picker-field">
          <text>{{visibilityOptions[visibilityIndex].label}}</text>
        </view>
      </picker>
      <view class="visibility-desc">{{visibilityOptions[visibilityIndex].desc}}</view>
      <view wx:if="{{visibilityIndex === 0}}" class="visibility-review-hint">公开模板需要审核通过后才会展示在广场</view>
    </view>

    <!-- Todo 项选择 -->
    <view class="form-group">
      <view class="input-label">选择要发布的项目</view>
      <view class="todo-select-list">
        <view
          wx:for="{{todos}}"
          wx:key="_id"
          class="todo-select-item {{item.selected ? 'todo-select-item--selected' : ''}}"
          data-index="{{index}}"
          bindtap="onToggleTodo"
        >
          <view class="todo-select-check"><view class="icon icon-md {{item.selected ? 'icon-check-square' : 'icon-square'}}"></view></view>
          <text class="todo-select-text">{{item.content}}</text>
        </view>
      </view>
    </view>

    <!-- 提交 -->
    <button
      class="btn btn-primary btn-block submit-btn"
      bindtap="onSubmit"
      disabled="{{submitting || !name}}"
    >
      {{submitting ? '发布中...' : '发布模板'}}
    </button>
  </view>
</view>
