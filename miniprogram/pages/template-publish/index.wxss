/* ===== 模板发布页 ===== */

.form {
  padding: var(--spacing-lg);
}

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* 模板描述 */
.desc-textarea {
  min-height: 120rpx;
  width: 100%;
  box-sizing: border-box;
  font-size: var(--font-md);
  line-height: 1.6;
}

.desc-counter {
  text-align: right;
  font-size: 22rpx;
  color: var(--color-text-placeholder);
  margin-top: 8rpx;
}

.input-label__hint {
  font-size: var(--font-sm);
  color: var(--color-text-placeholder);
  font-weight: 400;
}

/* 自定义标签 */
.custom-tag-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.custom-tag-input {
  flex: 1;
  height: 68rpx;
  background: var(--color-bg);
  border-radius: var(--radius-lg);
  padding: 0 24rpx;
  font-size: var(--font-sm);
  color: var(--color-text);
}

.custom-tag-add-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  height: 68rpx;
  padding: 0 24rpx;
  background: var(--color-primary-light);
  color: var(--color-primary);
  border-radius: var(--radius-lg);
  font-size: var(--font-sm);
  font-weight: 500;
  flex-shrink: 0;
}

.custom-tag-add-btn:active {
  opacity: 0.7;
}

.visibility-desc {
  font-size: var(--font-sm);
  color: var(--color-text-placeholder);
  margin-top: 12rpx;
  padding-left: 4rpx;
}

.visibility-review-hint {
  font-size: 22rpx;
  color: #FF9F0A;
  margin-top: 8rpx;
  padding-left: 4rpx;
}

.todo-select-list {
  background-color: var(--color-bg-white);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.todo-select-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border-light);
  transition: background-color var(--transition-fast);
  min-height: 88rpx;
  box-sizing: border-box;
}

.todo-select-item:last-child {
  border-bottom: none;
}

.todo-select-item:active {
  background-color: var(--color-bg);
}

.todo-select-item--selected {
  background-color: var(--color-primary-light);
}

.todo-select-item--selected:active {
  background-color: var(--color-primary-soft);
}

.todo-select-check {
  font-size: var(--font-lg);
  color: var(--color-primary);
  flex-shrink: 0;
}

.todo-select-text {
  font-size: var(--font-md);
  flex: 1;
  color: var(--color-text);
}

.submit-btn {
  margin-top: var(--spacing-2xl);
  height: 92rpx;
  line-height: 92rpx;
}
