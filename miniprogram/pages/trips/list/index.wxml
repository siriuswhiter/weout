<view class="page">
  <!-- 顶部标题栏 -->
  <view class="header">
    <view class="header__left">
      <view class="header__title">一起出游</view>
      <view class="header__subtitle">和朋友一起准备出发</view>
    </view>
    <view class="header__actions">
      <view class="header__btn" bindtap="onJoinByCode">
        <view class="icon icon-sm icon-users" style="margin-right: 4rpx;"></view>
        加入
      </view>
      <view class="header__btn header__btn--primary" bindtap="onCreateTrip">
        <view class="icon icon-sm icon-plus" style="margin-right: 4rpx;"></view>
        新行程
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{isEmpty}}">
    <view class="empty-state-icon"><view class="icon icon-xxl icon-backpack"></view></view>
    <view class="empty-state-text">还没有行程</view>
    <view class="empty-state-hint">创建一个行程，开始准备出发吧</view>
    <button class="btn btn-primary empty-state-action" bindtap="onCreateTrip">
      <view class="icon icon-sm icon-plus" style="margin-right: 8rpx;"></view>
      创建行程
    </button>
  </view>

  <!-- 行程列表 -->
  <view class="page-content" wx:else>
    <!-- 进行中 -->
    <view wx:if="{{activeTrips.length > 0}}">
      <view class="section-title">进行中</view>
      <trip-card
        wx:for="{{activeTrips}}"
        wx:key="_id"
        trip="{{item}}"
        bind:triptap="onTripTap"
        bind:triplongpress="onTripLongPress"
      />
    </view>

    <!-- 已结束 -->
    <view wx:if="{{archivedTrips.length > 0}}" class="archived-section">
      <view class="section-title">已结束</view>
      <trip-card
        wx:for="{{archivedTrips}}"
        wx:key="_id"
        trip="{{item}}"
        archived="{{true}}"
        bind:triptap="onTripTap"
        bind:triplongpress="onTripLongPress"
      />
    </view>
  </view>

  <!-- 首次使用欢迎引导 -->
  <welcome-modal show="{{showWelcome}}" bind:done="onWelcomeDone" />
</view>
