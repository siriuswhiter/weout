<view class="page">
  <view class="form">
    <!-- 行程名称 -->
    <view class="form-group">
      <view class="input-label">行程名称 *</view>
      <input
        class="input-field"
        placeholder="例如：三亚之旅、周末露营"
        value="{{name}}"
        bindinput="onNameInput"
        maxlength="30"
      />
    </view>

    <!-- 目的地 -->
    <view class="form-group">
      <view class="input-label">目的地</view>
      <input
        class="input-field"
        placeholder="去哪里？（可选）"
        value="{{destination}}"
        bindinput="onDestinationInput"
        maxlength="30"
      />
    </view>

    <!-- 出发日期 -->
    <view class="form-group">
      <view class="input-label">出发日期</view>
      <picker mode="date" value="{{startDate}}" start="{{today}}" bindchange="onStartDateChange">
        <view class="input-field picker-field">
          <text wx:if="{{startDate}}">{{startDate}}</text>
          <text wx:else class="placeholder">选择出发日期（可选）</text>
        </view>
      </picker>
    </view>

    <!-- 结束日期 -->
    <view class="form-group">
      <view class="input-label">结束日期</view>
      <picker mode="date" value="{{endDate}}" start="{{startDate || today}}" bindchange="onEndDateChange">
        <view class="input-field picker-field">
          <text wx:if="{{endDate}}">{{endDate}}</text>
          <text wx:else class="placeholder">选择结束日期（可选）</text>
        </view>
      </picker>
    </view>

    <!-- 提交按钮 -->
    <button
      class="btn btn-primary btn-block submit-btn"
      bindtap="onSubmit"
      disabled="{{submitting || !name}}"
    >
      {{submitting ? '创建中...' : '创建行程'}}
    </button>
  </view>
</view>
