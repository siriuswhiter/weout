/* ===== 邀请页 ===== */

.invite-page {
  padding: var(--spacing-lg);
  display: flex;
  justify-content: center;
  padding-top: 100rpx;
}

.invite-card {
  background-color: var(--color-bg-white);
  border-radius: var(--radius-2xl);
  padding: 56rpx 40rpx;
  text-align: center;
  width: 100%;
  box-shadow: var(--shadow-lg);
  position: relative;
  overflow: hidden;
}

/* 顶部装饰 */
.invite-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: linear-gradient(90deg, var(--color-primary) 0%, #6B8AFF 50%, var(--color-accent) 100%);
}

.invite-card__title {
  font-size: var(--font-md);
  color: var(--color-text-secondary);
  font-weight: 500;
}

.invite-card__trip-name {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--color-text);
  margin-top: 12rpx;
  line-height: 1.3;
}

.invite-card__code-section {
  margin: 48rpx 0;
  padding: 36rpx;
  background: linear-gradient(135deg, var(--color-primary-light) 0%, #E8ECFF 100%);
  border-radius: var(--radius-xl);
}

.invite-card__label {
  font-size: var(--font-sm);
  color: var(--color-text-placeholder);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.invite-card__code {
  font-size: 72rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 12rpx;
  font-family: 'Courier New', monospace;
}

.invite-card__hint {
  font-size: var(--font-xs);
  color: var(--color-text-placeholder);
  margin-top: 16rpx;
  line-height: 1.5;
}

.invite-card__actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.invite-card__actions .btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
}
