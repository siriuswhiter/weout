.trip-info {
  background-color: var(--color-bg-white);
  padding: 24rpx 32rpx;
  margin-bottom: 8rpx;
}

.trip-info__meta {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.trip-info__members {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.member-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background-color: var(--color-bg);
  padding: 8rpx 20rpx 8rpx 8rpx;
  border-radius: var(--radius-round);
}

.member-chip__avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 600;
}

.member-chip__avatar--add {
  background-color: transparent;
  border: 2rpx dashed var(--color-text-disabled);
  color: var(--color-text-disabled);
  font-size: 28rpx;
  font-weight: 400;
}

.member-chip--add {
  padding-right: 8rpx;
}

.member-chip__name {
  font-size: var(--font-sm);
  color: var(--color-text);
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 8rpx 32rpx 16rpx;
}

.filter-tab {
  font-size: var(--font-sm);
  padding: 8rpx 24rpx;
  border-radius: var(--radius-round);
  background-color: var(--color-bg-gray);
  color: var(--color-text-secondary);
}

.filter-tab--active {
  background-color: var(--color-primary);
  color: #ffffff;
}

/* Todo 列表 */
.todo-list {
  padding: 0 32rpx;
  padding-bottom: 160rpx;
}

.todo-list__card {
  background-color: var(--color-bg-white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}
