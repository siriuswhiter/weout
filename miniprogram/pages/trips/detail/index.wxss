/* ===== 行程详情页 ===== */

/* 行程头部 */
.trip-header {
  background-color: var(--color-bg-white);
  padding: 24rpx 32rpx 20rpx;
  margin-bottom: 4rpx;
}

.trip-header__top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.trip-header__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  flex: 1;
}

.trip-header__meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.trip-header__more {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: var(--color-bg-gray);
  color: var(--color-text-secondary);
  margin-top: -4rpx;
}

.trip-header__more:active {
  background-color: var(--color-border);
}

.trip-header__members {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

/* 成员胶囊 */
.member-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background-color: var(--color-bg);
  padding: 8rpx 20rpx 8rpx 8rpx;
  border-radius: var(--radius-round);
  transition: background-color var(--transition-fast);
}

.member-chip:active {
  background-color: var(--color-border);
}

.member-chip__avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-inverse);
  font-size: 20rpx;
  font-weight: 600;
}

.member-chip__avatar-img {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.member-chip__avatar--add {
  background-color: transparent;
  border: 2rpx dashed var(--color-primary-soft);
  color: var(--color-primary);
}

.member-chip--add {
  padding-right: 8rpx;
  background-color: var(--color-primary-light);
}

.member-chip--add:active {
  background-color: var(--color-primary-soft);
}

.member-chip__name {
  font-size: var(--font-sm);
  color: var(--color-text);
  font-weight: 500;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 32rpx;
  white-space: nowrap;
  background-color: var(--color-bg-white);
  border-bottom: 1rpx solid var(--color-border-light);
  overflow-x: auto;
  overflow-y: visible;
}

.filter-tab {
  display: inline-flex;
  font-size: var(--font-sm);
  padding: 10rpx 28rpx;
  border-radius: var(--radius-round);
  background-color: var(--color-bg-gray);
  color: var(--color-text-secondary);
  font-weight: 500;
  flex-shrink: 0;
  transition: all var(--transition-fast);
}

.filter-tab--active {
  background: linear-gradient(135deg, var(--color-primary) 0%, #6B8AFF 100%);
  color: var(--color-text-inverse);
  box-shadow: 0 4rpx 12rpx rgba(79, 110, 247, 0.25);
}

/* 状态与标签之间的分隔线 */
.filter-divider {
  width: 4rpx;
  min-width: 4rpx;
  height: 28rpx;
  background-color: var(--color-border);
  border-radius: 2rpx;
  flex-shrink: 0;
  margin: 0 6rpx;
}

/* Todo 列表 */
.todo-list {
  padding: 20rpx 32rpx;
  padding-bottom: 160rpx;
}

.todo-list__card {
  background-color: var(--color-bg-white);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

/* FAB 悬浮按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(60rpx + env(safe-area-inset-bottom));
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary) 0%, #6B8AFF 100%);
  color: var(--color-text-inverse);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(79, 110, 247, 0.4);
  z-index: 100;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.fab:active {
  transform: scale(0.92);
  box-shadow: 0 4rpx 16rpx rgba(79, 110, 247, 0.3);
}
