/* ===== 行程详情页 ===== */

/* 行程头部 */
.trip-header {
  background-color: var(--color-bg-white);
  padding: 24rpx 32rpx 20rpx;
  margin-bottom: 4rpx;
}

.trip-header__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.trip-header__meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.trip-header__members {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

/* 成员胶囊 */
.member-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background-color: var(--color-bg);
  padding: 8rpx 20rpx 8rpx 8rpx;
  border-radius: var(--radius-round);
  transition: background-color var(--transition-fast);
}

.member-chip:active {
  background-color: var(--color-border);
}

.member-chip__avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-inverse);
  font-size: 20rpx;
  font-weight: 600;
}

.member-chip__avatar--add {
  background-color: transparent;
  border: 2rpx dashed var(--color-primary-soft);
  color: var(--color-primary);
}

.member-chip--add {
  padding-right: 8rpx;
  background-color: var(--color-primary-light);
}

.member-chip--add:active {
  background-color: var(--color-primary-soft);
}

.member-chip__name {
  font-size: var(--font-sm);
  color: var(--color-text);
  font-weight: 500;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 32rpx 20rpx;
  background-color: var(--color-bg-white);
  border-bottom: 1rpx solid var(--color-border-light);
}

.filter-tab {
  font-size: var(--font-sm);
  padding: 10rpx 28rpx;
  border-radius: var(--radius-round);
  background-color: var(--color-bg-gray);
  color: var(--color-text-secondary);
  font-weight: 500;
  transition: all var(--transition-fast);
}

.filter-tab--active {
  background: linear-gradient(135deg, var(--color-primary) 0%, #6B8AFF 100%);
  color: var(--color-text-inverse);
  box-shadow: 0 4rpx 12rpx rgba(79, 110, 247, 0.25);
}

/* Todo 列表 */
.todo-list {
  padding: 20rpx 32rpx;
  padding-bottom: 180rpx;
}

.todo-list__card {
  background-color: var(--color-bg-white);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}
