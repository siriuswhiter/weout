<view class="page">
  <view class="loading" wx:if="{{loading}}">加载中...</view>

  <view wx:else>
    <!-- 行程信息头部 -->
    <view class="trip-header">
      <view class="trip-header__top">
        <view class="trip-header__meta">
          <view class="trip-header__meta-item" wx:if="{{dateText}}">
            <view class="icon icon-sm icon-calendar"></view>
            <text>{{dateText}}</text>
          </view>
          <view class="trip-header__meta-item" wx:if="{{trip.destination}}">
            <view class="icon icon-sm icon-map-pin"></view>
            <text>{{trip.destination}}</text>
          </view>
          <view class="trip-header__meta-item">
            <view class="icon icon-sm icon-users"></view>
            <text>{{members.length}}人</text>
          </view>
        </view>
        <!-- 更多操作 -->
        <view class="trip-header__more" bindtap="onShowMore">
          <view class="icon icon-sm icon-dots-three"></view>
        </view>
      </view>
      <!-- 成员列表 -->
      <view class="trip-header__members">
        <view
          wx:for="{{members}}"
          wx:key="_id"
          class="member-chip"
        >
          <image wx:if="{{item.avatarUrl}}" class="member-chip__avatar-img" src="{{item.avatarUrl}}" mode="aspectFill" />
          <view wx:else class="member-chip__avatar" style="background-color: {{item.color}}">{{item.text}}</view>
          <text class="member-chip__name">{{item.nickName}}</text>
        </view>
        <view class="member-chip member-chip--add" bindtap="onInvite">
          <view class="member-chip__avatar member-chip__avatar--add">
            <view class="icon icon-sm icon-plus"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 筛选栏（状态 + 标签合并为一行） -->
    <view class="filter-bar">
      <view
        class="filter-tab {{filter === 'all' ? 'filter-tab--active' : ''}}"
        data-filter="all"
        bindtap="onFilterChange"
      >全部</view>
      <view
        class="filter-tab {{filter === 'mine' ? 'filter-tab--active' : ''}}"
        data-filter="mine"
        bindtap="onFilterChange"
      >我的</view>
      <view
        class="filter-tab {{filter === 'undone' ? 'filter-tab--active' : ''}}"
        data-filter="undone"
        bindtap="onFilterChange"
      >未完成</view>
      <!-- 标签筛选（动态从 todos 中提取） -->
      <view wx:if="{{todoTags.length > 0}}" class="filter-divider"></view>
      <view
        wx:for="{{todoTags}}"
        wx:key="*this"
        class="filter-tab {{tagFilter === item ? 'filter-tab--active' : ''}}"
        data-tag="{{item}}"
        bindtap="onTagFilterChange"
      >{{item}}</view>
    </view>

    <!-- Todo 列表 -->
    <view class="todo-list">
      <view class="empty-state" wx:if="{{filteredTodos.length === 0}}">
        <view class="empty-state-icon"><view class="icon icon-xxl icon-note-pencil"></view></view>
        <view class="empty-state-text">暂无待办事项</view>
        <view class="empty-state-hint">点击右下角 + 添加</view>
      </view>

      <view class="todo-list__card" wx:else>
        <todo-item
          wx:for="{{filteredTodos}}"
          wx:key="_id"
          todo="{{item}}"
          members="{{members}}"
          bind:toggle="onToggleTodo"
          bind:delete="onDeleteTodo"
          bind:edit="onEditTodo"
        />
      </view>
    </view>

    <!-- FAB 悬浮按钮 -->
    <view class="fab" bindtap="onShowAddModal">
      <view class="icon icon-lg icon-plus"></view>
    </view>

    <!-- 添加/编辑 Todo 弹窗 -->
    <add-todo-modal
      id="addTodoModal"
      show="{{showAddModal}}"
      members="{{members}}"
      existingTags="{{todoTags}}"
      bind:confirm="onConfirmTodo"
      bind:close="onCloseAddModal"
    />
  </view>
</view>
