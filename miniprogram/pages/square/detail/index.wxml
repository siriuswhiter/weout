<view class="page">
  <view class="loading" wx:if="{{loading}}">加载中...</view>

  <view wx:else>
    <!-- 模板信息 -->
    <view class="template-header">
      <view class="template-header__name">{{template.name}}</view>
      <view class="template-header__creator" wx:if="{{creatorInfo}}">
        <image wx:if="{{creatorInfo.avatarUrl}}" class="creator-avatar-img" src="{{creatorInfo.avatarUrl}}" mode="aspectFill" />
        <view wx:else class="creator-avatar" style="background-color: {{creatorInfo.color}}">{{creatorInfo.text}}</view>
        <text class="creator-name">{{creatorInfo.nickName}}</text>
      </view>
      <view class="template-header__tags" wx:if="{{template.tags.length > 0}}">
        <view wx:for="{{template.tags}}" wx:key="*this" class="tag tag-default">{{item}}</view>
      </view>
      <view class="template-header__stats">
        <text><view class="icon icon-sm icon-thumbs-up" style="margin-right: 4rpx;"></view> {{template.likeCount || 0}}</text>
        <text style="margin-left: 32rpx;"><view class="icon icon-sm icon-download" style="margin-right: 4rpx;"></view> {{template.useCount || 0}} 次使用</text>
      </view>
    </view>

    <!-- Todo 项列表 -->
    <view class="template-items">
      <view class="section-title" style="padding: 0 32rpx;">清单内容（{{template.items.length}} 项）</view>
      <view class="items-card">
        <view
          wx:for="{{template.items}}"
          wx:key="index"
          class="template-item"
        >
          <view class="template-item__circle {{item.priority === 'urgent' ? 'template-item__circle--urgent' : item.priority === 'high' ? 'template-item__circle--high' : ''}}"><view class="icon icon-sm icon-circle"></view></view>
          <view class="template-item__main">
            <view class="template-item__content">{{item.content}}</view>
            <view class="template-item__meta" wx:if="{{(item.tags && item.tags.length > 0) || item.priority === 'high' || item.priority === 'urgent'}}">
              <view wx:if="{{item.priority === 'urgent'}}" class="item-badge item-badge--urgent">紧急</view>
              <view wx:elif="{{item.priority === 'high'}}" class="item-badge item-badge--high">重要</view>
              <view wx:for="{{item.tags}}" wx:for-item="tg" wx:key="*this" class="item-badge item-badge--tag">{{tg}}</view>
            </view>
          </view>
          <view class="tag tag-warning" wx:if="{{item.assignType === 'all'}}" style="font-size: 20rpx; padding: 4rpx 12rpx;">所有人</view>
        </view>
      </view>
    </view>

    <!-- 底部操作栏 -->
    <view class="bottom-bar">
      <button class="btn {{isLiked ? 'btn-liked' : 'btn-secondary'}}" bindtap="onToggleLike">
        <view class="icon icon-sm {{isLiked ? 'icon-heart-fill' : 'icon-heart'}}" style="margin-right: 8rpx;"></view> {{template.likeCount || 0}}
      </button>
      <button class="btn btn-primary flex-1" bindtap="onUseTemplate">
        一键使用
      </button>
    </view>
  </view>
</view>
