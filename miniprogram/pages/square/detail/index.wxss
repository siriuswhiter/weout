/* ===== 模板详情页 ===== */

.template-header {
  background-color: var(--color-bg-white);
  padding: 32rpx;
  margin-bottom: 12rpx;
}

.template-header__name {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.3;
}

.template-header__creator {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
}

.creator-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-inverse);
  font-size: 20rpx;
  font-weight: 600;
}

.creator-avatar-img {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
}

.creator-name {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  font-weight: 500;
}

.template-header__tags {
  display: flex;
  gap: 10rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.template-header__stats {
  display: flex;
  align-items: center;
  font-size: var(--font-sm);
  color: var(--color-text-placeholder);
  margin-top: 20rpx;
  gap: 32rpx;
}

.template-header__stats text {
  display: flex;
  align-items: center;
}

/* 清单内容 */
.template-items {
  padding: 16rpx 0;
  padding-bottom: 180rpx;
}

.items-card {
  background-color: var(--color-bg-white);
  border-radius: var(--radius-xl);
  margin: 12rpx 32rpx 0;
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.template-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--color-border-light);
  gap: 16rpx;
}

.template-item:last-child {
  border-bottom: none;
}

.template-item__circle {
  color: var(--color-primary-soft);
  font-size: var(--font-lg);
  flex-shrink: 0;
  margin-top: 4rpx;
}

.template-item__circle--high {
  color: #FF9F0A;
}

.template-item__circle--urgent {
  color: #FF6B6B;
}

.template-item__main {
  flex: 1;
  min-width: 0;
}

.template-item__content {
  font-size: var(--font-md);
  color: var(--color-text);
}

.template-item__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.item-badge {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: var(--radius-round);
  line-height: 1.6;
}

.item-badge--tag {
  background-color: var(--color-primary-light);
  color: var(--color-primary);
}

.item-badge--high {
  background-color: #FFF8EC;
  color: #FF9F0A;
}

.item-badge--urgent {
  background-color: #FFF0F0;
  color: #FF6B6B;
}

/* 点赞按钮 */
.btn-liked {
  background-color: var(--color-accent-light);
  color: var(--color-accent);
}

.btn-liked:active {
  opacity: 0.85;
}
