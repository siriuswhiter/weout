<view class="page profile-page">
  <!-- 用户信息区域 -->
  <view class="profile-header">
    <view class="profile-header__bg"></view>
    <view class="profile-header__content">
      <view class="avatar-wrapper">
        <button class="avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
          <image wx:if="{{userInfo.avatarUrl}}" class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
          <view wx:else class="avatar-placeholder" style="background: {{avatarColor}}">
            {{avatarText}}
          </view>
        </button>
        <view class="avatar-edit-hint">
          <view class="icon icon-sm icon-note-pencil"></view>
        </view>
      </view>
      <view class="nickname-wrapper">
        <input type="nickname" class="nickname-input" value="{{userInfo.nickName || '点击设置昵称'}}" bindblur="onNicknameChange" placeholder="点击设置昵称" />
      </view>
    </view>
  </view>

  <!-- 管理员审核入口 -->
  <view wx:if="{{isAdmin}}" class="admin-section" bindtap="onGoReview">
    <view class="admin-entry">
      <view class="admin-entry__left">
        <view class="icon icon-md icon-shield-check" style="color: #4F6EF7; margin-right: 12rpx;"></view>
        <text class="admin-entry__title">模板管理</text>
      </view>
      <view class="admin-entry__right">
        <view wx:if="{{pendingCount > 0}}" class="admin-entry__badge">{{pendingCount}}</view>
        <view class="icon icon-sm icon-caret-right" style="color: var(--color-text-placeholder);"></view>
      </view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="section {{isAdmin ? 'section--after-admin' : ''}}">
    <view class="section-header">
      <text class="section__title">我的模板</text>
      <view class="section-count-badge">{{myTemplates.length}}</view>
    </view>

    <!-- 模板列表 -->
    <view wx:if="{{myTemplates.length > 0}}" class="template-list">
      <template-card
        wx:for="{{myTemplates}}"
        wx:key="_id"
        template="{{item}}"
        showDelete="{{true}}"
        showStatus="{{true}}"
        bind:templatetap="onTemplateTap"
        bind:templatedelete="onDeleteTemplate"
      />
    </view>

    <!-- 空状态 -->
    <view wx:elif="{{!loading}}" class="empty-state">
      <view class="empty-state-icon"><view class="icon icon-xxl icon-list-checks"></view></view>
      <view class="empty-state-text">还没有发布模板</view>
      <view class="empty-state-hint">在行程详情中可以将清单发布为模板</view>
    </view>

    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="loading">
      <text>加载中...</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="onLogout">退出登录</button>
  </view>
</view>
