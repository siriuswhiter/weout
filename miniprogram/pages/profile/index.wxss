/* ===== 个人页 ===== */

.profile-page {
  padding-bottom: 120rpx;
}

/* 用户信息头部 */
.profile-header {
  position: relative;
  overflow: hidden;
}

.profile-header__bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--color-primary) 0%, #6B8AFF 50%, #8B9FFF 100%);
}

.profile-header__content {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 60rpx;
}

/* 头像 */
.avatar-wrapper {
  position: relative;
  margin-bottom: 24rpx;
}

.avatar-btn {
  width: 160rpx !important;
  height: 160rpx !important;
  border-radius: 50% !important;
  padding: 0 !important;
  margin: 0 !important;
  overflow: hidden;
  background: transparent;
  line-height: normal;
  border: 6rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: var(--color-text-inverse);
  font-weight: 600;
}

.avatar-edit-hint {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--color-bg-white);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  color: var(--color-primary);
}

/* 昵称 */
.nickname-wrapper {
  width: 100%;
  display: flex;
  justify-content: center;
}

.nickname-input {
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-inverse);
  max-width: 400rpx;
  padding: 8rpx 20rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.3);
}

/* 管理员入口 */
.admin-section {
  margin: -32rpx 24rpx 0;
  position: relative;
}

.admin-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--color-bg-white);
  border-radius: var(--radius-xl);
  padding: 28rpx 32rpx;
  box-shadow: var(--shadow-md);
}

.admin-entry__left {
  display: flex;
  align-items: center;
}

.admin-entry__title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.admin-entry__right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.admin-entry__badge {
  background: #FF6B6B;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 36rpx;
  padding: 0 10rpx;
}

/* 功能区块 */
.section {
  margin: -32rpx 24rpx 0;
  position: relative;
  background: var(--color-bg-white);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  box-shadow: var(--shadow-md);
}

.section--after-admin {
  margin-top: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.section-count-badge {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-primary);
  background-color: var(--color-primary-light);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-round);
  min-width: 40rpx;
  text-align: center;
}

/* 模板列表 */
.template-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 退出登录 */
.logout-section {
  margin: 48rpx 24rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  color: var(--color-danger);
  background: var(--color-bg-white);
  border-radius: var(--radius-xl);
  border: 2rpx solid var(--color-danger-light);
  box-shadow: var(--shadow-xs);
}

.logout-btn::after {
  border: none;
}

.logout-btn:active {
  background-color: var(--color-danger-light);
}
