.profile-page {
  padding-bottom: 120rpx;
}

/* 用户信息头部 */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 60rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, var(--color-primary-light, #e8f5e9) 100%);
}

.avatar-wrapper {
  margin-bottom: 24rpx;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  overflow: hidden;
  background: transparent;
  line-height: normal;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: #fff;
  font-weight: 600;
}

.nickname-wrapper {
  width: 100%;
  display: flex;
  justify-content: center;
}

.nickname-input {
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  max-width: 400rpx;
  padding: 8rpx 20rpx;
  border-bottom: 2rpx solid transparent;
}

.nickname-input:focus {
  border-bottom-color: var(--color-primary);
}

/* 功能区块 */
.section {
  margin: 24rpx;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.section-count {
  font-size: 24rpx;
  color: var(--color-text-light);
}

/* 模板列表 */
.template-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-light);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--color-text-lighter, #bbb);
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-light);
}

/* 退出登录 */
.logout-section {
  margin: 48rpx 24rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  color: #e74c3c;
  background: #fff;
  border-radius: var(--radius-lg);
  border: 2rpx solid #f5d5d5;
  box-shadow: var(--shadow-sm);
}

.logout-btn::after {
  border: none;
}
