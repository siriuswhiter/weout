/* ===== 行程卡片 ===== */

.trip-card {
  background-color: var(--color-bg-white);
  border-radius: var(--radius-xl);
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  position: relative;
  overflow: hidden;
  transition: box-shadow var(--transition-fast);
}

.trip-card:active {
  box-shadow: var(--shadow-sm);
}

.trip-card--archived {
  opacity: 0.55;
}

/* 顶部装饰条 */
.trip-card__accent {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--color-primary) 0%, #6B8AFF 50%, var(--color-accent) 100%);
  border-radius: 6rpx 6rpx 0 0;
}

.trip-card__body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.trip-card__info {
  flex: 1;
  min-width: 0;
}

.trip-card__name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
}

.trip-card__meta {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-top: 10rpx;
}

.trip-card__meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: var(--font-sm);
  color: var(--color-text-placeholder);
}

.trip-card__right {
  text-align: right;
  flex-shrink: 0;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.trip-card__progress {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-round);
  line-height: 1.4;
}

.trip-card__members {
  display: flex;
  justify-content: flex-end;
}

.trip-card__avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-inverse);
  font-size: 20rpx;
  font-weight: 600;
  margin-left: -10rpx;
  border: 3rpx solid var(--color-bg-white);
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.08);
}

.trip-card__avatar:first-child {
  margin-left: 0;
}

.trip-card__avatar-img {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  margin-left: -10rpx;
  border: 3rpx solid var(--color-bg-white);
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
}

.trip-card__avatar-img:first-child {
  margin-left: 0;
}

.trip-card__member-count {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-bg-gray);
  color: var(--color-text-placeholder);
  font-size: 18rpx;
  font-weight: 500;
  margin-left: -10rpx;
  border: 3rpx solid var(--color-bg-white);
}
