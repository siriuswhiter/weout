<view class="trip-card {{archived ? 'trip-card--archived' : ''}}" bindtap="onTap" bindlongpress="onLongPress">
  <!-- 顶部装饰条 -->
  <view class="trip-card__accent" wx:if="{{!archived}}"></view>
  
  <view class="trip-card__body">
    <view class="trip-card__info">
      <view class="trip-card__name">{{trip.name}}</view>
      <view class="trip-card__meta">
        <view class="trip-card__meta-item" wx:if="{{dateText}}">
          <view class="icon icon-sm icon-calendar"></view>
          <text>{{dateText}}</text>
        </view>
        <view class="trip-card__meta-item" wx:if="{{trip.destination}}">
          <view class="icon icon-sm icon-map-pin"></view>
          <text>{{trip.destination}}</text>
        </view>
      </view>
    </view>
    <view class="trip-card__right">
      <view class="trip-card__progress" style="color: {{progressColor}}; background-color: {{progressBgColor}}">{{progressText}}</view>
      <view class="trip-card__members">
        <view
          wx:for="{{memberList}}"
          wx:key="_id"
          class="trip-card__avatar"
          style="background-color: {{item.color}}"
        >{{item.text}}</view>
        <view class="trip-card__member-count" wx:if="{{trip.memberIds.length > 4}}">+{{trip.memberIds.length - 4}}</view>
      </view>
    </view>
  </view>
</view>
