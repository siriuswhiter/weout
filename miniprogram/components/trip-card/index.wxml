<view class="trip-card {{archived ? 'trip-card--archived' : ''}}" bindtap="onTap" bindlongpress="onLongPress">
  <view class="trip-card__body">
    <view class="trip-card__info">
      <view class="trip-card__name">{{trip.name}}</view>
      <view class="trip-card__date">📅 {{dateText}}</view>
      <view class="trip-card__destination" wx:if="{{trip.destination}}">📍 {{trip.destination}}</view>
    </view>
    <view class="trip-card__right">
      <view class="trip-card__progress" style="color: {{progressColor}}">{{progressText}}</view>
      <view class="trip-card__members">
        <view
          wx:for="{{memberList}}"
          wx:key="_id"
          class="trip-card__avatar"
          style="background-color: {{item.color}}"
        >{{item.text}}</view>
        <view class="trip-card__member-count" wx:if="{{trip.memberIds.length > 4}}">+{{trip.memberIds.length - 4}}</view>
      </view>
    </view>
  </view>
</view>
