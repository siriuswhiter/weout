.member-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.member-option {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 24rpx;
  border-radius: var(--radius-round);
  background-color: var(--color-bg);
  font-size: var(--font-sm);
  color: var(--color-text);
}

.member-option--active {
  background-color: var(--color-warning-light);
  border: 2rpx solid var(--color-warning);
  color: #e67700;
}

.member-option__avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 16rpx;
  font-weight: 600;
}
