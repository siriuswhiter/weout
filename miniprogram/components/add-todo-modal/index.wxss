/* ===== 添加 Todo 弹窗 ===== */

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(26, 26, 46, 0.45);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}

.modal-sheet {
  width: 100%;
  background-color: var(--color-bg-white);
  border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  padding: 0 32rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  max-height: 85vh;
  overflow-y: auto;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.08);
}

.modal-sheet__handle {
  display: flex;
  justify-content: center;
  padding: 16rpx 0;
}

.modal-sheet__bar {
  width: 64rpx;
  height: 8rpx;
  background-color: var(--color-border);
  border-radius: 4rpx;
}

.modal-sheet__title {
  font-size: var(--font-lg);
  font-weight: 700;
  margin-bottom: 28rpx;
  color: var(--color-text);
}

.form-group {
  margin-bottom: 28rpx;
}

.placeholder-text {
  color: var(--color-text-placeholder);
}

/* 日期选择行 */
.due-date-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.due-date-picker {
  flex: 1;
}

/* Picker 输入框 */
.picker-field {
  display: flex;
  align-items: center;
  min-height: 88rpx;
}

.clear-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-placeholder);
  font-size: var(--font-md);
  border-radius: 50%;
  background-color: var(--color-bg-gray);
  flex-shrink: 0;
}

.clear-btn:active {
  background-color: var(--color-border);
}

.note-input {
  min-height: 120rpx;
  width: 100%;
  line-height: 1.6;
}

.confirm-btn {
  margin-top: 16rpx;
  height: 92rpx;
  line-height: 92rpx;
}
