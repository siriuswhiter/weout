.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}

.modal-sheet {
  width: 100%;
  background-color: var(--color-bg-white);
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 32rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  max-height: 85vh;
  overflow-y: auto;
}

.modal-sheet__handle {
  display: flex;
  justify-content: center;
  padding: 16rpx 0;
}

.modal-sheet__bar {
  width: 72rpx;
  height: 8rpx;
  background-color: var(--color-text-disabled);
  border-radius: 4rpx;
}

.modal-sheet__title {
  font-size: var(--font-lg);
  font-weight: 700;
  margin-bottom: 24rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.placeholder-text {
  color: var(--color-text-placeholder);
}

.due-date-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.picker-field {
  display: flex;
  align-items: center;
  min-height: 44rpx;
}

.clear-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-placeholder);
  font-size: var(--font-md);
}

.note-input {
  min-height: 80rpx;
  width: 100%;
}

.confirm-btn {
  margin-top: 16rpx;
  height: 88rpx;
  line-height: 88rpx;
}
