<view class="modal-overlay" wx:if="{{show}}" bindtap="onClose">
  <view class="modal-sheet" catchtap="preventBubble">
    <!-- 拖拽条 -->
    <view class="modal-sheet__handle">
      <view class="modal-sheet__bar"></view>
    </view>

    <view class="modal-sheet__title">{{isEdit ? '编辑待办' : '添加待办'}}</view>

    <!-- 内容输入 -->
    <view class="form-group">
      <input
        class="input-field"
        placeholder="输入待办事项..."
        value="{{content}}"
        bindinput="onContentInput"
        focus="{{show}}"
        maxlength="100"
      />
    </view>

    <!-- 标签输入 -->
    <view class="form-group">
      <view class="input-label">标签（可选，输入后按回车添加）</view>
      <view class="tags-input-wrap">
        <view wx:for="{{tags}}" wx:key="*this" class="tag-chip">
          <text class="tag-chip__text">{{item}}</text>
          <view class="tag-chip__remove" data-index="{{index}}" bindtap="onRemoveTag">×</view>
        </view>
        <input
          class="tags-input"
          placeholder="{{tags.length > 0 ? '继续添加...' : '输入标签，如：美食、交通...'}}"
          value="{{tagInput}}"
          bindinput="onTagInput"
          bindconfirm="onTagConfirm"
          maxlength="20"
        />
      </view>
      <!-- 选择已有标签 -->
      <view wx:if="{{existingTags.length > 0}}" class="existing-tags">
        <view class="existing-tags__label">选择已有标签</view>
        <view class="existing-tags__list">
          <view
            wx:for="{{existingTags}}"
            wx:key="*this"
            class="existing-tag {{tags.indexOf(item) > -1 ? 'existing-tag--active' : ''}}"
            data-tag="{{item}}"
            bindtap="onSelectExistingTag"
          >{{item}}</view>
        </view>
      </view>
    </view>

    <!-- 优先级 -->
    <view class="form-group">
      <view class="input-label">重要程度</view>
      <view class="priority-wrap">
        <view
          wx:for="{{todoPriorities}}"
          wx:key="value"
          class="priority-option {{priority === item.value ? 'priority-option--active' : ''}} priority-option--{{item.value}}"
          data-value="{{item.value}}"
          bindtap="onPriorityTap"
        >{{item.label}}</view>
      </view>
    </view>

    <!-- 指派人 -->
    <view class="form-group">
      <view class="input-label">指派给</view>
      <member-selector
        members="{{members}}"
        assignType="{{assignType}}"
        selectedIds="{{selectedIds}}"
        bind:change="onMemberChange"
      />
    </view>

    <!-- 截止时间 -->
    <view class="form-group">
      <view class="input-label">截止时间（可选）</view>
      <view class="due-date-row">
        <picker class="due-date-picker" mode="date" value="{{dueDate}}" start="{{today}}" bindchange="onDueDateChange">
          <view class="input-field picker-field">
            <text wx:if="{{dueDate}}">{{dueDate}}</text>
            <text wx:else class="placeholder-text">选择日期</text>
          </view>
        </picker>
        <view wx:if="{{dueDate}}" class="clear-btn" bindtap="onClearDueDate"><view class="icon icon-sm icon-x"></view></view>
      </view>
    </view>

    <!-- 备注 -->
    <view class="form-group">
      <view class="input-label">备注（可选）</view>
      <textarea
        class="input-field note-input"
        placeholder="添加备注信息..."
        value="{{note}}"
        bindinput="onNoteInput"
        maxlength="200"
        auto-height
      />
    </view>

    <!-- 确认按钮 -->
    <button class="btn btn-primary btn-block confirm-btn" bindtap="onConfirm" disabled="{{!content}}">
      {{isEdit ? '保存修改' : '确认添加'}}
    </button>
  </view>
</view>
