.welcome-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.welcome-modal {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 48rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.welcome-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.5;
}

/* 头像 */
.welcome-avatar-wrap {
  margin-bottom: 32rpx;
}

.welcome-avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  overflow: hidden;
  background: transparent;
  line-height: normal;
  border: none;
}

.welcome-avatar-btn::after {
  border: none;
}

.welcome-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.welcome-avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #f5f5f5;
  border: 3rpx dashed #ccc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.welcome-avatar-plus {
  font-size: 48rpx;
  color: #ccc;
  line-height: 1;
}

.welcome-avatar-hint {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 4rpx;
}

/* 昵称输入 */
.welcome-input-wrap {
  width: 100%;
  margin-bottom: 40rpx;
}

.welcome-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  text-align: center;
  box-sizing: border-box;
}

/* 按钮 */
.welcome-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.welcome-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.welcome-btn::after {
  border: none;
}

.welcome-btn--primary {
  background: var(--color-primary, #007aff);
  color: #fff;
}

.welcome-skip {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #999;
  padding: 8rpx 24rpx;
}
