/* ===== 欢迎弹窗 ===== */

.welcome-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(26, 26, 46, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.welcome-modal {
  width: 600rpx;
  background: var(--color-bg-white);
  border-radius: var(--radius-2xl);
  padding: 60rpx 48rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.15);
}

.welcome-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.welcome-desc {
  font-size: 26rpx;
  color: var(--color-text-placeholder);
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.6;
}

/* 头像 */
.welcome-avatar-wrap {
  margin-bottom: 36rpx;
}

.welcome-avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  overflow: hidden;
  background: transparent;
  line-height: normal;
  border: none;
}

.welcome-avatar-btn::after {
  border: none;
}

.welcome-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.welcome-avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary-light) 0%, #E8ECFF 100%);
  border: 3rpx dashed var(--color-primary-soft);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.welcome-avatar-plus {
  font-size: 48rpx;
  color: var(--color-primary);
  line-height: 1;
  font-weight: 300;
}

.welcome-avatar-hint {
  font-size: 20rpx;
  color: var(--color-primary);
  margin-top: 4rpx;
  opacity: 0.7;
}

/* 昵称输入 */
.welcome-input-wrap {
  width: 100%;
  margin-bottom: 40rpx;
}

.welcome-input {
  width: 100%;
  height: 92rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 0 24rpx;
  font-size: 30rpx;
  text-align: center;
  box-sizing: border-box;
  transition: border-color var(--transition-fast);
}

.welcome-input:focus {
  border-color: var(--color-primary);
}

/* 按钮 */
.welcome-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.welcome-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: var(--radius-xl);
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.welcome-btn::after {
  border: none;
}

.welcome-btn--primary {
  background: linear-gradient(135deg, var(--color-primary) 0%, #6B8AFF 100%);
  color: var(--color-text-inverse);
  box-shadow: 0 8rpx 24rpx rgba(79, 110, 247, 0.3);
}

.welcome-btn--primary:active {
  opacity: 0.9;
}

.welcome-skip {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: var(--color-text-placeholder);
  padding: 8rpx 24rpx;
}
