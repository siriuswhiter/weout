/* ===== 模板卡片 ===== */

.template-card {
  background-color: var(--color-bg-white);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-card);
  transition: box-shadow var(--transition-fast);
}

.template-card:active {
  box-shadow: var(--shadow-sm);
}

.template-card__body {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.template-card__info {
  flex: 1;
  min-width: 0;
}

.template-card__name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.template-card__name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.3;
}

.template-card__status {
  flex-shrink: 0;
  font-size: 20rpx;
  font-weight: 500;
  padding: 2rpx 12rpx;
  border-radius: var(--radius-round);
  line-height: 1.6;
}

/* 描述 */
.template-card__desc {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  margin-top: 8rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 标签 */
.template-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.template-card__tag {
  font-size: 20rpx;
  color: var(--color-primary);
  background: var(--color-primary-light);
  padding: 2rpx 14rpx;
  border-radius: var(--radius-round);
  line-height: 1.6;
}

.template-card__preview {
  font-size: var(--font-sm);
  color: var(--color-text-placeholder);
  margin-top: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.template-card__reject-note {
  font-size: 22rpx;
  color: #FF6B6B;
  margin-top: 8rpx;
  line-height: 1.4;
}

.template-card__creator {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.template-card__stats {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: var(--color-text-placeholder);
  margin-top: 14rpx;
  gap: 24rpx;
}

.template-card__stats text {
  display: flex;
  align-items: center;
}

.template-card__actions {
  flex-shrink: 0;
  margin-left: 24rpx;
  margin-top: 4rpx;
}

.template-card__action {
  margin-bottom: 8rpx;
}

.template-card__review-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.btn-approve {
  background: #34C759;
  color: #fff;
  border: none;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: var(--radius-lg);
  text-align: center;
}

.btn-approve:active {
  opacity: 0.8;
}

.btn-reject {
  background: var(--color-bg-white);
  color: #FF6B6B;
  border: 2rpx solid #FFD4D4;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: var(--radius-lg);
  text-align: center;
}

.btn-reject:active {
  background-color: #FFF0F0;
}

.btn-danger {
  background: var(--color-bg-white);
  color: var(--color-danger);
  border: 2rpx solid var(--color-danger-light);
}

.btn-danger:active {
  background-color: var(--color-danger-light);
}
